# ==========================================
# Discord Bot Configuration - EXAMPLE FILE
# ==========================================
# Copy this file to .env and fill in your actual values

# ------------------------------------------
# Discord Bot Credentials
# ------------------------------------------
TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here

# ------------------------------------------
# Bot Settings
# ------------------------------------------
PREFIX=!
OWNER_ID=your_owner_id_here

# ------------------------------------------
# Database Configuration
# ------------------------------------------
MONGO_URL=mongodb://localhost:27017/discordbot

# ------------------------------------------
# Embed/Component Colors (Hex format)
# ------------------------------------------
DEFAULT_COLOR=#5865F2
ERROR_COLOR=#ED4245
SUCCESS_COLOR=#57F287
INFO_COLOR=#5865F2
WARN_COLOR=#FEE75C

# ------------------------------------------
# Production Settings
# ------------------------------------------
PRODUCTION=false
GUILD_ID=your_test_guild_id_here
